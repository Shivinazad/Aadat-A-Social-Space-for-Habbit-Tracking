# Production Environment Variables for Render

# Database (provided by Render PostgreSQL)
DATABASE_URL=<will-be-auto-filled-by-render>

# JWT Secret (CHANGE THIS!)
JWT_SECRET=your_super_secret_jwt_key_please_change_this_in_production_12345

# Node Environment
NODE_ENV=production

# Port (provided by Render)
PORT=<will-be-auto-filled-by-render>

# Client URL (your Render app URL)
CLIENT_URL=https://aadat-app.onrender.com

# Email Configuration (Optional - for invitation feature)
# Get app password from Gmail: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
