# ============ Server ============
# MongoDB Atlas connection string (free M0 tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aadat?retryWrites=true&w=majority

# Security (REQUIRED in production — use long random strings)
JWT_SECRET=your_secret_key_min_32_chars
SESSION_SECRET=your_session_secret_min_32_chars

# App config
NODE_ENV=production
PORT=3000

# Your deployed URL (e.g. https://aadat.onrender.com)
CLIENT_URL=https://your-app.onrender.com

# OAuth callback URLs (update domain to match your deployment)
GOOGLE_CALLBACK_URL=https://your-app.onrender.com/api/users/auth/google/callback
GITHUB_CALLBACK_URL=https://your-app.onrender.com/api/users/auth/github/callback

# OAuth credentials (from Google Console / GitHub Developer Settings)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Email (Gmail SMTP — use App Password, not account password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# AI Roadmap (free from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key

# ============ Client ============
# Only needed if frontend is deployed separately from backend
# VITE_API_BASE_URL=https://your-app.onrender.com/api
